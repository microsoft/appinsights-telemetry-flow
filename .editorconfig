# EditorConfig — https://editorconfig.org
root = true

# Defaults for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# PowerShell scripts — CRLF (Windows convention)
[*.ps1]
end_of_line = crlf

# Bash scripts — LF
[*.sh]
end_of_line = lf

# Markdown — trailing whitespace can be intentional (line breaks)
[*.md]
trim_trailing_whitespace = false

# YAML (GitHub Actions, issue templates)
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2
